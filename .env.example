# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# Optional: Guild ID for development command registration (instant updates)
# Leave blank for global registration (production)
GUILD_ID=

# MongoDB connection string (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/crystalmine?retryWrites=true&w=majority

# Comma-separated Discord User IDs that can use /admin commands
ADMIN_USER_IDS=your_discord_user_id_here
